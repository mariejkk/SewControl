@inherits LayoutComponentBase
@inject AuthService AuthSvc
@inject NavigationManager Nav

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>

    <MudAppBar Elevation="1"
               Style="background-color:white; height:56px ">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Default"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Persistent"
               Width="225px"
               Elevation="2"
               Style="background-color:#71064B;">

        <MudNavMenu>

            <MudStack Row AlignItems="AlignItems.Center"
                      Class="px-4 pt-4 pb-2"
                      Style="background-color:#AE0774;">

                <img src="images/SewContorllogo.png" style="height:20px;" />

                <MudText Typo="Typo.h6"
                         Style="color:white; font-weight:bold;">
                    SewControl
                </MudText>

            </MudStack>

            <MudDivider Class="my-0" Style="background-color:#2E2E40;" />

            <MudNavLink Href="/" Match="NavLinkMatch.All" Style="color:white;">
                <MudIcon Icon ="@Icons.Material.Filled.Home"
                        Style="color:white;"/>
                Inicio
            </MudNavLink>

            <MudNavLink Href="/dashboard" Style="color:white;">
    
                <MudIcon Icon="@Icons.Material.Filled.Dashboard"
                         Style="color:white;"/>
                Dashboard
            </MudNavLink>

            <MudNavLink Href="/encargos" Style="color:white;">
    
                <MudIcon Icon="@Icons.Material.Filled.Assignment"
                         Style="color:white;" />
                Encargos
            </MudNavLink>

            <MudNavLink Href="/clientes" Style="color:white;">
    
                <MudIcon Icon="@Icons.Material.Filled.People"
                         Style="color:white;" />
                Clientes
            </MudNavLink>

            <MudNavLink Href="/Costureras" Style="color:white;">
    
                <MudIcon Icon="@Icons.Material.Filled.ContentCut"
                         Style="color:white;" />
                Costureras
            </MudNavLink>

            <MudSpacer />

            <MudDivider Class="my-2" Style="background-color:#2E2E40;" />

            <MudNavLink OnClick="Logout" Style="color:white;">

                <MudIcon Icon="@Icons.Material.Filled.Logout"
                         Style="color:white; margin-right:8px;" />

                Cerrar Sesión
            </MudNavLink>

        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Style="background-color:#F5F6FA; min-height:100vh;">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthSvc.IsAuthenticatedAsync())
            Nav.NavigateTo("/login");
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task Logout()
    {
        await AuthSvc.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}