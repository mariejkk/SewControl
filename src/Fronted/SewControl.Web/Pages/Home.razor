@page "/"
@inject EncargoService EncargoSvc
@inject ClienteService ClienteSvc
@inject CostureraService CostureraeSvc

<PageTitle>Dashboard - SewControl</PageTitle>
<MudText Typo="Typo.h5" Class="mb-5">Dashboard</MudText>

@if (_cargando)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-4" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="background-color:#FFFFFC;">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h4"><b>@_encargos.Count</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Encargos</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="background-color:#FFFFFC;">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.HourglassTop" Color="Color.Warning" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h4"><b>@_pendientes</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Pendientes</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="background-color:#FFFFFC;">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h4"><b>@_listos</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Listos</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="background-color:#FFFFFC;">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h4"><b>@_clientes.Count</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Clientes</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_atrasados.Count > 0)
    {
        <MudAlert Severity="Severity.Warning" Class="mt-4">
            ⚠️ Hay <b>@_atrasados.Count</b> encargo(s) atrasados.
        </MudAlert>
    }

    <MudText Typo="Typo.h6" Class="mt-6 mb-3">Encargos Recientes</MudText>
    <MudPaper Elevation="2">
        <MudTable Items="@_encargos.Take(8)" Hover Dense>
            <HeaderContent>
                <MudTh>#</MudTh>
                <MudTh>Cliente</MudTh>
                <MudTh>Costurera</MudTh>
                <MudTh>Tipo</MudTh>
                <MudTh>Estado</MudTh>
                <MudTh>Entrega</MudTh>
                <MudTh>Total</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Id</MudTd>
                <MudTd>@context.NombreCliente</MudTd>
                <MudTd>@context.NombreCosturera</MudTd>
                <MudTd>@context.Tipo</MudTd>
                <MudTd>
                    <MudChip T="string" Color="@GetColor(context.Estado)" Size="Size.Small">@context.Estado</MudChip>
                </MudTd>
                <MudTd>
                    <MudText Color="@(context.EstaAtrasado ? Color.Error : Color.Default)">
                        @context.FechaEntregaEstimada.ToString("dd/MM/yyyy")
                    </MudText>
                </MudTd>
                <MudTd>RD$@context.PrecioTotal.ToString("N2")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<EncargoDto> _encargos = new();
    private List<ClienteDto> _clientes = new();
    private List<EncargoDto> _atrasados = new();
    private int _pendientes, _listos;
    private bool _cargando = true;

    protected override async Task OnInitializedAsync()
    {
        _encargos = await EncargoSvc.GetAllAsync();
        _clientes = await ClienteSvc.GetAllAsync();
        _pendientes = _encargos.Count(e => e.Estado == EstadoEncargo.Pendiente || e.Estado == EstadoEncargo.EnProceso);
        _listos = _encargos.Count(e => e.Estado == EstadoEncargo.Listo);
        _atrasados = _encargos.Where(e => e.EstaAtrasado).ToList();
        _cargando = false;
    }

    private Color GetColor(EstadoEncargo e) => e switch
    {
        EstadoEncargo.Pendiente => Color.Warning,
        EstadoEncargo.EnProceso => Color.Info,
        EstadoEncargo.Listo => Color.Success,
        EstadoEncargo.Entregado => Color.Default,
        EstadoEncargo.Cancelado => Color.Error,
        _ => Color.Default
    };
}
