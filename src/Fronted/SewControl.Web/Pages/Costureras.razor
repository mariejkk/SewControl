@page "/costureras"
@inject CostureraService CostureraeSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject HttpClient Http

<PageTitle>Costureras - SewControl</PageTitle>

<MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Costureras</MudText>
    <MudButton Variant="Variant.Filled" Style="background-color:#8F2B78;color:white;"
               StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="Abrir">
        Nueva Costurera
    </MudButton>
</MudStack>

@if (_cargando)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" />
}
else
{
    <MudPaper Elevation="2">
        <MudTable Items="@_costureras" Hover Filter="new Func<CostureraDto, bool>(Filtrar)">
            
            <ToolBarContent>
                <MudTextField @bind-Value="_busqueda" Placeholder="Buscar..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate />
            </ToolBarContent>

            <HeaderContent>
                <MudTh>Nombre</MudTh>
                <MudTh>Teléfono</MudTh>
                <MudTh>Especialidad</MudTh>
                <MudTh>Encargos</MudTh>
                <MudTh>Estado</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>@context.NombreCompleto</MudTd>
                <MudTd>@context.Telefono</MudTd>
                <MudTd>@(context.Especialidad ?? "-")</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                        @context.EncargosActivos
                    </MudChip>
                </MudTd>

                <MudTd>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(context.Activa ? Color.Success : Color.Default)">
                        @(context.Activa ? "Activa" : "Inactiva")
                    </MudChip>
                </MudTd>

                <MudTd>
                    <MudIconButton Icon="@(context.Activa ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                   Size="Size.Small"
                                   Color="@(context.Activa ? Color.Success : Color.Default)"
                                   OnClick="@(() => Toggle(context))" />

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@(() => Editar(context))" />

                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => ConfirmarEliminar(context))" />
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <MudText>No hay costureras registradas.</MudText>
            </NoRecordsContent>

        </MudTable>
    </MudPaper>
}

@if (_showForm)
{
    <MudOverlay Visible="_showForm" DarkBackground ZIndex="1000" />
    <div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1001;width:520px;max-width:90vw;">
        <MudPaper Elevation="8" Class="pa-6">
            <MudText Typo="Typo.h6" Class="mb-4">@(_editando ? "Editar Costurera" : "Nueva Costurera")</MudText>
            @if (_errores.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">
                    @foreach (var e in _errores)
                    {
                        <div>• @e</div>
                    }
                </MudAlert>
            }
            <MudGrid>
                <MudItem xs="6"><MudTextField @bind-Value="_form.Nombre" Label="Nombre" Required /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_form.Apellido" Label="Apellido" Required /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_form.Telefono" Label="Teléfono" Required /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_form.Especialidad" Label="Especialidad" /></MudItem>
            </MudGrid>
            <MudStack Row Justify="Justify.FlexEnd" Class="mt-4" Spacing="2">
                <MudButton OnClick="@(() => _showForm = false)">Cancelar</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Guardar">Guardar</MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    private string _busqueda = "";

    private bool Filtrar(CostureraDto c) =>
    string.IsNullOrEmpty(_busqueda) ||
    c.NombreCompleto.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ||
    c.Telefono.Contains(_busqueda) ||
    (c.Especialidad != null && c.Especialidad.Contains(_busqueda, StringComparison.OrdinalIgnoreCase));

    private List<CostureraDto> _costureras = new();
    private bool _cargando = true, _showForm = false;
    private CreateCostureraDto _form = new();
    private List<string> _errores = new();
    private bool _editando = false;    
    private int _editandoId;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        _costureras = await CostureraeSvc.GetAllAsync();
        _cargando = false;
    }

    private void Abrir()
    {
        _form = new();
        _errores = new();
        _editando = false;  
        _showForm = true;
    }
    private void Editar(CostureraDto c)
    {
        _editandoId = c.Id;
        _form = new CreateCostureraDto
        {
            Nombre = c.Nombre,
            Apellido = c.Apellido,
            Telefono = c.Telefono,
            Especialidad = c.Especialidad
        };
        _errores = new();
        _editando = true;
        _showForm = true;
    }


    private async Task Guardar()
{
        _errores = new();
        if (_editando)
        {
            (bool ok, string? msg) = await CostureraeSvc.UpdateAsync(_editandoId, _form);
            if (ok) { Snackbar.Add(msg ?? "Costurera actualizada.", Severity.Success); _showForm = false; _editando = false; await Cargar(); }
        }
    else
    {
        var (ok, msg, errors) = await CostureraeSvc.CreateAsync(_form);
        if (ok) { Snackbar.Add(msg ?? "Costurera registrada.", Severity.Success); _showForm = false; await Cargar(); }
        else _errores = errors ?? new List<string> { msg ?? "Error." };
    }
}

    private async Task Toggle(CostureraDto c)
    {
        await CostureraeSvc.ToggleActivaAsync(c.Id);
        await Cargar();
    }

    private async Task Eliminar(CostureraDto c)
    {
        if (await CostureraeSvc.DeleteAsync(c.Id))
        { Snackbar.Add("Costurera eliminada.", Severity.Success); await Cargar(); }
    }

    private async Task ConfirmarEliminar(CostureraDto costurera)
    {
        bool? resultado = await DialogService.ShowMessageBox(
            "⚠️ Confirmación",
            $"¿Estás seguro de que deseas eliminar a {costurera.NombreCompleto}?",
            yesText: "Eliminar",
            cancelText: "Cancelar"
        );

        if (resultado == true)
        {
            await Eliminar(costurera);
        }
    }
}
